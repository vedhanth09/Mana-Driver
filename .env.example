# MongoDB Atlas connection string
MONGO_URI=

# JWT secrets (generate with: openssl rand -hex 32)
JWT_SECRET=
JWT_REFRESH_SECRET=

# Cloudinary credentials
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Public base URL (e.g. http://localhost:3000)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Resend (transactional email) — https://resend.com
# RESEND_FROM must be a verified sender; onboarding@resend.dev works in dev only.
RESEND_API_KEY=
RESEND_FROM=ManaDriver <onboarding@resend.dev>

# Runtime mode: development | production | test
NODE_ENV=development
